{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs"]
        },
        "build": {
          "cmds": ["cd Server && npm install"]
        }
      },
      "start": {
        "cmd": "cd Server && node index.js"
      }
    }
  }
}
